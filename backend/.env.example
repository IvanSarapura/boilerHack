# Motor de base de datos: el código es agnóstico, solo cambia esta URL.
# Default sin Docker (arranca al instante):
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Alternativas (descomenta una y ajusta credenciales):
# PostgreSQL (docker-compose):
# DATABASE_URL=postgresql+asyncpg://boilerhack:boilerhack@localhost:5432/boilerhack
# MySQL / MariaDB:
# DATABASE_URL=mysql+aiomysql://boilerhack:boilerhack@localhost:3306/boilerhack
# SQL Server (requiere msodbcsql18 en el SO):
# DATABASE_URL=mssql+aioodbc://sa:Your_password123@localhost:1433/boilerhack?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=yes

# Orígenes permitidos por CORS (separados por coma)
CORS_ORIGINS=http://localhost:3000

APP_ENV=development
LOG_LEVEL=info
